# Copy to .env (gitignored). Secrets ONLY — non-secret config lives in rules.yml.

# --- Qualys VMDR ---
QUALYS_USERNAME=your_qualys_api_user
QUALYS_PASSWORD=your_qualys_api_password
# Platform API root for your POD (no trailing /api). Examples:
#   US Platform 2: https://qualysapi.qg2.apps.qualys.com
#   EU Platform 1: https://qualysapi.qg1.apps.qualys.eu
QUALYS_API_URL=https://qualysapi.qg2.apps.qualys.com

# --- Jira Cloud ---
JIRA_BASE_URL=https://your-site.atlassian.net
JIRA_EMAIL=you@example.com
# Classic (unscoped) API token from id.atlassian.com -> Security -> API tokens.
JIRA_API_TOKEN=ATATT...

# --- State store (PostgreSQL only; no Redis) ---
QJSYNC_DATABASE_URL=postgresql+psycopg://qjsync:qjsync@localhost:5432/qjsync
